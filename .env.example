# Polymarket Trading Engine Configuration
# Copy this file to .env and fill in your values

# =====================
# MODE SELECTION
# =====================
# FREE  - Data collection and analysis only (no trading)
# PAPER - Paper trading with simulated orders
# PRO   - Live trading with real money
TRADING_MODE=FREE

# =====================
# TELEGRAM CONFIG
# =====================
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get your chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# =====================
# LLM CONFIG (MiniMax)
# =====================
# Get your API key from MiniMax developer portal
MINIMAX_API_KEY=your_minimax_api_key_here

# =====================
# POLYMARKET API (PRO MODE ONLY)
# =====================
# Get your API credentials from Polymarket
POLYMARKET_API_KEY=your_polymarket_api_key_here
POLYMARKET_API_SECRET=your_polymarket_api_secret_here

# =====================
# TRADING PARAMETERS
# =====================
# Initial capital for paper/pro trading
# PAPER: 10000 (simulated)
# PRO: 10 (real money - only what you can afford to lose!)
INITIAL_CAPITAL=10

# Risk management
RISK_PER_TRADE_PCT=0.5
MAX_DAILY_LOSS_PCT=2.0
